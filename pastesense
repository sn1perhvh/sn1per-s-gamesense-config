local function get_rainbow(speed, offset)
    local t = (globals.curtime() * speed + offset) % 1
    local i = t * 6
    local f = i - math.floor(i)
    local q = 1 - f
    if i < 1 then return 255, f*255, 0 elseif i < 2 then return q*255, 255, 0 elseif i < 3 then return 0, 255, f*255
    elseif i < 4 then return 0, q*255, 255 elseif i < 5 then return f*255, 0, 255 else return 255, 0, q*255 end
end

local function lerp(a, b, t) return a + (b - a) * t end


client.set_event_callback("paint", function()
 
    if not ui.get(hat_enabled) then return end

    if not ui.get(thirdperson_enabled) or not ui.get(thirdperson_key) then 
        return 
    end

    local me = entity.get_local_player()
    if not me or not entity.is_alive(me) then return end

    local h_x, h_y, h_z = entity.hitbox_position(me, 0)
    if h_x == nil then return end

    local offset = ui.get(hat_offset)
    local height = ui.get(hat_height)
    local radius = ui.get(hat_radius)
    local mode = ui.get(hat_mode)
    
    local r1, g1, b1, a1 = ui.get(hat_color1)
    local r2, g2, b2, a2 = ui.get(hat_color2)

    local cx, cy = renderer.world_to_screen(h_x, h_y, h_z + offset + height)
    if not cx then return end

    local segments = 60
    local step = (math.pi * 2) / segments

    for i = 0, segments do
        local angle = i * step
        local next_angle = (i + 1) * step

        local x1, y1 = h_x + math.cos(angle) * radius, h_y + math.sin(angle) * radius
        local x2, y2 = h_x + math.cos(next_angle) * radius, h_y + math.sin(next_angle) * radius

        local sx1, sy1 = renderer.world_to_screen(x1, y1, h_z + offset)
        local sx2, sy2 = renderer.world_to_screen(x2, y2, h_z + offset)

        if sx1 and sx2 then
            local r, g, b, a = r1, g1, b1, a1
            if mode == "Rainbow" then
                r, g, b = get_rainbow(0.5, i * 0.02)
            elseif mode == "Gradient" then
                local fraction = i / segments
                r = lerp(r1, r2, fraction)
                g = lerp(g1, g2, fraction)
                b = lerp(b1, b2, fraction)
                a = lerp(a1, a2, fraction)
            end

            renderer.line(sx1, sy1, sx2, sy2, r, g, b, a)
            renderer.line(sx1, sy1, cx, cy, r, g, b, a / 2.5)
        end
    end
end)
