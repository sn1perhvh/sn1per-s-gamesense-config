    if not enabled_px then 
        return 
    end

    set_standard_esp(false)

    local local_player = entity.get_local_player()
    local players_px = entity.get_players() 
    
    r_px, g_px, b_px, a_menu_px = ui.get(esp_color_px)
    static_enabled_px = ui.get(static_hp_enabled_px)
    sr_px, sg_px, sb_px, _ = ui.get(static_hp_color_px)
    icons_on_px = ui.get(ref_weaponicon_px)

    for i=1, #players_px do
        p_px = players_px[i]

        if not entity.is_dormant(p_px) and entity.is_alive(p_px) and p_px ~= local_player then
            x1_px, y1_px, x2_px, y2_px, alpha_esp_px = entity.get_bounding_box(p_px)
            
            if x1_px ~= nil and alpha_esp_px > 0 then
                final_a_px = a_menu_px * alpha_esp_px
                bar_h_px = y2_px - y1_px
                name_px = entity.get_player_name(p_px)
                w_n_px, _ = surface_px.get_text_size(pixel_font_px, name_px)
                surface_px.draw_text(x1_px + (x2_px - x1_px)/2 - (w_n_px/2), y1_px - 15, r_px, g_px, b_px, final_a_px, pixel_font_px, name_px)

                weapon_ent_px = entity.get_player_weapon(p_px)
                if weapon_ent_px ~= nil then
                    weapon_raw_px = entity.get_classname(weapon_ent_px)
                    if weapon_raw_px then
                        w_name_px = weapon_raw_px:gsub("C", "", 1):gsub("Weapon", ""):upper()
                        w_name_px = weapon_names_custom_px[w_name_px] or w_name_px:lower()
                        
                        w_w_px, _ = surface_px.get_text_size(pixel_font_px, w_name_px)
                        y_offset_px = icons_on_px and 18 or 6
                        surface_px.draw_text(x1_px + (x2_px - x1_px)/2 - (w_w_px/2), y2_px + y_offset_px, r_px, g_px, b_px, final_a_px, pixel_font_px, w_name_px)
                    end
                end

                flags_px = {}
                armor_px = entity.get_prop(p_px, "m_ArmorValue") or 0
                if armor_px > 0 then
                    helm_px = entity.get_prop(p_px, "m_bHasHelmet") == 1
                    table.insert(flags_px, helm_px and "hk" or "k")
                end
                if entity.get_prop(p_px, "m_bIsScoped") == 1 then table.insert(flags_px, "scoped") end
                
                for f=1, #flags_px do
                    surface_px.draw_text(x2_px + 6, y1_px + (f-1)*10, r_px, g_px, b_px, final_a_px, pixel_font_px, flags_px[f])
                end

                health_px = entity.get_prop(p_px, "m_iHealth") or 0
                if health_px > 0 then
                    hp_p_px = math.min(1, health_px / 100)
                    cur_h_px = bar_h_px * hp_p_px
                    bx_px = x1_px - 6
                    
                    surface_px.draw_filled_rect(bx_px - 1, y1_px - 1, 4, bar_h_px + 2, 0, 0, 0, final_a_px * 0.6)

                    if static_enabled_px then
                        rr_px, rg_px, rb_px = sr_px, sg_px, sb_px
                    else
                        rr_px, rg_px, rb_px = math.min(255, 510 * (1 - hp_p_px)), math.min(255, 510 * hp_p_px), 0
                    end
                    
                    surface_px.draw_filled_rect(bx_px, y2_px - cur_h_px, 2, cur_h_px, rr_px, rg_px, rb_px, final_a_px)
                    
                    if health_px < 100 then
                        hp_txt_px = tostring(health_px)
                        tw_px, th_px = surface_px.get_text_size(pixel_font_px, hp_txt_px)
