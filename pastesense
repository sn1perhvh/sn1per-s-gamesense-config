local function on_paint(ctx)
    if not ui_get(enabled_reference) then return end

    local realtime = globals_realtime()
    local r, g, b, picker_a = ui_get(color_reference)

    for player, data in pairs(damage_indicator_displays) do
        local damage, time, x, y, z = data[1], data[2], data[3], data[4], data[5]
        
        if realtime - time < STATIC_DURATION then
            local sx, sy = client_world_to_screen(ctx, x, y, z)
            if sx ~= nil then
                local alpha_fade = 1.0
                local time_diff = realtime - time
                
                if time_diff > (STATIC_DURATION * 0.7) then
                    alpha_fade = 1 - ((time_diff - (STATIC_DURATION * 0.7)) / (STATIC_DURATION * 0.3))
                end

                local text = tostring(damage)
                local w, h = surface.get_text_size(damage_font, text)
                surface.draw_text(sx - w/2, sy, r, g, b, picker_a * alpha_fade, damage_font, text)
            end

            data[5] = z + (STATIC_SPEED * 0.1)
        else
            damage_indicator_displays[player] = nil
        end
    end
end

