local hit_marker_color = ui_new_color_picker("LUA", "B", "Hit marker color", 255, 255, 255, 255)

-- В функции paint() ищем отрисовку линий и меняем цвет
local function paint()
    if not ui_get(hit_marker) then
        return
    end

    -- Получаем значения из колорпикера
    local r, g, b, a = ui_get(hit_marker_color)
    local size = 2.5
    local size2 = 2.5

    for tick, data in pairs(shot_data) do
        if data.draw then
            if globals_curtime() >= data.time then
                data.alpha = data.alpha - 2
            end

            if data.alpha <= 0 then
                data.alpha = 0
                data.draw = false
            end

            local sx, sy = renderer_world_to_screen(data.x, data.y, data.z)
            if sx ~= nil then
                -- Высчитываем итоговую прозрачность (учитываем альфу из пикера и затухание)
                local current_alpha = math.min(a, data.alpha)
                local shadow_alpha = math.max(0, current_alpha - 35)

                -- Отрисовка линий с выбранным цветом
                -- Тень (черная обводка)
                renderer_line(sx + size, sy + size, sx + (size * size2), sy + (size * size2), 0, 0, 0, current_alpha)
                -- Основная линия (твой цвет)
                renderer_line(sx + size, sy + size, sx + (size * size2), sy + (size * size2), r, g, b, shadow_alpha)

                renderer_line(sx - size, sy + size, sx - (size * size2), sy + (size * size2), 0, 0, 0, current_alpha)
                renderer_line(sx - size, sy + size, sx - (size * size2), sy + (size * size2), r, g, b, shadow_alpha)

                renderer_line(sx + size, sy - size, sx + (size * size2), sy - (size * size2), 0, 0, 0, current_alpha)
                renderer_line(sx + size, sy - size, sx + (size * size2), sy - (size * size2), r, g, b, shadow_alpha)

                renderer_line(sx - size, sy - size, sx - (size * size2), sy - (size * size2), 0, 0, 0, current_alpha)
                renderer_line(sx - size, sy - size, sx - (size * size2), sy - (size * size2), r, g, b, shadow_alpha)
            end
        end
    end
end

local function player_hurt(e)
    if not ui_get(hit_marker) then
        return
    end

    local victim_entindex = client_userid_to_entindex(e.userid)
    local attacker_entindex = client_userid_to_entindex(e.attacker)

    if attacker_entindex ~= entity_get_local_player() then
        return
    end

    local tick = globals_tickcount()
    local data = shot_data[tick]

    if shot_data[tick] == nil or data.impacts == nil then
        return
    end

    local hitgroups = { 
        [1] = {0, 1}, 
        [2] = {4, 5, 6}, 
        [3] = {2, 3}, 
        [4] = {13, 15, 16}, 
        [5] = {14, 17, 18}, 
        [6] = {7, 9, 11}, 
        [7] = {8, 10, 12}
    }

    local impacts = data.impacts
    local hitboxes = hitgroups[e.hitgroup]
    
    local hit = nil
    local closest = math.huge

    for i=1, #impacts do
        local impact = impacts[i]

        if hitboxes ~= nil then
            for j=1, #hitboxes do
                local x, y, z = entity_hitbox_position(victim_entindex, hitboxes[j])
                local distance = math_sqrt((impact.x - x)^2 + (impact.y - y)^2 + (impact.z - z)^2)

                if distance < closest then
                    hit = impact
                    closest = distance
                end
            end
        end
    end

    if hit == nil then
        return
    end

    shot_data[tick] = {
        x = hit.x,
        y = hit.y,
        z = hit.z,
        time = globals_curtime() + 1 - 0.25,
        alpha = 255,
        damage = e.dmg_health,
        hs = e.hitgroup == 0 or e.hitgroup == 1,
        draw = true,
    }
end

local function bullet_impact(e)
    if not ui_get(hit_marker) then
        return
    end

    if client_userid_to_entindex(e.userid) ~= entity_get_local_player() then
        return
    end

    local tick = globals_tickcount()

    if shot_data[tick] == nil then
        shot_data[tick] = {
            impacts = { }
        }
    end

    local impacts = shot_data[tick].impacts

    if impacts == nil then
        impacts = { }
    end

    impacts[#impacts + 1] = {
        x = e.x,
        y = e.y,
        z = e.z
    }
end

local function round_start()
    if not ui_get(hit_marker) then
        return
    end

    shot_data = { }
end

