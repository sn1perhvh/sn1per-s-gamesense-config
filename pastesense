local function json_encode(table)
    return panorama.loadstring([[
        return JSON.stringify(]] .. panorama.loadstring("return " .. table)() .. [[)
    ]])()
end

    local function serializeTable(val)
        local t = type(val)
        if t == "table" then
            local tmp = {}
            local is_list = #val > 0 and (function()
                local count = 0
                for _ in pairs(val) do count = count + 1 end
                return count == #val
            end)()
            
            for k, v in pairs(val) do
                local key = is_list and "" or "[" .. (type(k) == "number" and k or '"' .. k .. '"') .. "]="
                table.insert(tmp, key .. serializeTable(v))
            end
            return "{" .. table.concat(tmp, ",") .. "}"
        elseif t == "string" then return string.format("%q", val)
        end
        return tostring(val)
    end

    ui.new_button("LUA", "B", "Export config", function()
        local idx = ui.get(cfg_list)
        if idx == nil or ps_cfg_list[idx + 1] == nil then
            client.log("[PasteSense] Select a config!")
            return
        end
        
        local name = ps_cfg_list[idx + 1]
        local data = database.read("ps_cfg_" .. name)
        
        if data then
            local str = serializeTable(data)
            clipboard.set(str)
            client.log("[PasteSense] Config '" .. name .. "' exported to clipboard!")
        else
            client.log("[PasteSense] Failed to read config data!")
        end
    end)

    ui.new_button("LUA", "B", "Import config", function()
        local buffer = clipboard.get()
        
        if not buffer or buffer == "" then
            client.log("[PasteSense] Clipboard is empty!")
            return
        end

        local status, func = pcall(load, "return " .. buffer)
        
        if status and type(func) == "function" then
            local ok, result = pcall(func)
            if ok and type(result) == "table" then
                apply(result)
                client.log("[PasteSense] Config imported successfully!")
            else
                client.log("[PasteSense] Invalid config data structure!")
            end
        else
            client.log("[PasteSense] Error decoding config from clipboard!")
        end
    end)


