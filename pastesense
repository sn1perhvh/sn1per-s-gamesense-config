snowflakes = snowflakes or {}
snowflakes_count = 36 
scr_w, scr_h = client.screen_size()
menu_was_open = false

function new_snowflake()
    local flake = {
        x0 = math.random() * scr_w,
        y = math.random() * scr_h,
        speed = 1.2 + math.random() * 1.5,
        amp = 10 + math.random() * 14,
        phase = math.random() * 6.28,
        omega = 0.01 + math.random() * 0.017,
        angle = 0,
        size = 6 + math.random() * 4
    }
    flake.x = flake.x0 + math.sin(flake.phase) * flake.amp
    return flake
end

function init_snowflakes()
    snowflakes = {}
    for i=1, snowflakes_count do
        snowflakes[i] = new_snowflake()
    end
end

function draw_snowflake(flake)
    local x = flake.x
    local y = flake.y
    local a = flake.angle

    renderer.circle(x, y, flake.size, 210, 230, 255, 180)
    renderer.circle(x, y, flake.size * 0.45, 240, 250, 255, 230)
    for theta = 0, 330, 60 do
        local ang = a + math.rad(theta)
        local x2 = x + math.cos(ang) * (flake.size * 1.05)
        local y2 = y + math.sin(ang) * (flake.size * 1.05)
        renderer.line(x, y, x2, y2, 220, 220, 255, 170)
    end
end

init_snowflakes()

client.set_event_callback("paint_ui", function()
    if not ui.is_menu_open() then
        if menu_was_open then
            snowflakes = {}
            menu_was_open = false
        end
        return
    end

    if not ui.get(menu_background) then
        return
    end

    if not menu_was_open then
        scr_w, scr_h = client.screen_size()
        init_snowflakes()
        menu_was_open = true
    end

    local w, h = client.screen_size()
    if w ~= scr_w or h ~= scr_h then
        scr_w = w
        scr_h = h
        init_snowflakes()
    end

    renderer.rectangle(0, 0, scr_w, scr_h, 0, 0, 0, 150)

    local realtime = globals.realtime()
    for i, flake in ipairs(snowflakes) do
        flake.x = flake.x0 + math.sin(flake.phase + realtime * 1.12) * flake.amp
        flake.angle = flake.angle + flake.omega
        draw_snowflake(flake)
        flake.y = flake.y + flake.speed

        if (flake.y > scr_h + flake.size) then
            flake.x0 = math.random() * scr_w
            flake.y = -flake.size * 2
            flake.speed = 1.2 + math.random() * 1.5
            flake.phase = math.random() * 6.28
            flake.amp = 10 + math.random() * 14
            flake.angle = 0
            flake.size = 6 + math.random() * 4
            flake.omega = 0.01 + math.random() * 0.017
        end
    end
end)
