        fade_timer  = math.max(fade_timer  - ft, 0)
        shake_timer = math.max(shake_timer - ft, 0)
        anim_scale  = anim_scale + (1.0 - anim_scale) * math.min(ft * 14, 1)

        if shake_timer <= 0 then
            shake_x = floor(shake_x * 0.6)
            shake_y = floor(shake_y * 0.6)
        end

        local is_rampage = count >= 5
        local fw = is_rampage and 300 or fw_base
        local fh = is_rampage and 110 or fh_base

        local sx = pos_x + shake_x
        local sy = pos_y + shake_y

        -- Драг мышкой
        local cur = client.cursor_position and client.cursor_position() or nil
        local mx  = cur and cur[1] or 0
        local my  = cur and cur[2] or 0
        local in_box  = mx >= pos_x - fw/2 and mx <= pos_x + fw/2
                     and my >= pos_y - fh/2 and my <= pos_y + fh/2

        -- Клик (кнопка 0 = левая мышь через client)
        if in_box and ui.is_menu_open() then
            if not dragging then
                dragging  = true
                drag_off_x = pos_x - mx
                drag_off_y = pos_y - my
            end
        end

        if dragging then
            if ui.is_menu_open() then
                pos_x = mx + drag_off_x
                pos_y = my + drag_off_y
                -- Клампим к экрану
                pos_x = math.max(fw/2, math.min(w - fw/2, pos_x))
                pos_y = math.max(fh/2, math.min(h - fh/2, pos_y))
            else
                dragging = false
            end
        end

        -- Подсказка что можно двигать
        if ui.is_menu_open() then
            renderer.text(pos_x, pos_y + fh/2 + 14, 150,150,150, 180, "c", 0, "[ drag to move ]")
            -- Рамка при наведении
            if in_box then
                renderer.line(pos_x-fw/2, pos_y-fh/2, pos_x+fw/2, pos_y-fh/2, 255,255,255, 80)
                renderer.line(pos_x-fw/2, pos_y+fh/2, pos_x+fw/2, pos_y+fh/2, 255,255,255, 80)
                renderer.line(pos_x-fw/2, pos_y-fh/2, pos_x-fw/2, pos_y+fh/2, 255,255,255, 80)
                renderer.line(pos_x+fw/2, pos_y-fh/2, pos_x+fw/2, pos_y+fh/2, 255,255,255, 80)
            end
        end

        if count > 0 and fade_timer > 0 then
            local cr, cg, cb = get_combo_color(count)
            local cname      = get_combo_name(count)

            local alpha = 255
            if fade_timer < 1.0 then
                alpha = floor(255 * fade_timer)
            end

            local pulse = (sin(t * 6) + 1) * 0.5
            local pr    = floor(cr * (0.8 + 0.2 * pulse))
            local pg    = floor(cg * (0.8 + 0.2 * pulse))
            local pb    = floor(cb * (0.8 + 0.2 * pulse))

            -- Рампага — внешнее свечение
            if is_rampage then
                local gp = floor((sin(t*8)+1)*0.5*25)
                renderer.rectangle(sx-fw/2-6, sy-fh/2-6, fw+12, fh+12, pr,pg,pb, floor(alpha*0.15)+gp)
                renderer.rectangle(sx-fw/2-3, sy-fh/2-3, fw+6,  fh+6,  pr,pg,pb, floor(alpha*0.25)+gp)
            end

            -- Фон
            renderer.rectangle(sx-fw/2-1, sy-fh/2-1, fw+2, fh+2, pr,pg,pb, floor(alpha*0.3))
            renderer.rectangle(sx-fw/2,   sy-fh/2,   fw,   fh,   0,0,0,     floor(alpha*0.75))

            -- Боковые полосы
            renderer.rectangle(sx-fw/2,     sy-fh/2, 3, fh, pr,pg,pb, alpha)
            renderer.rectangle(sx+fw/2-3,   sy-fh/2, 3, fh, pr,pg,pb, alpha)

            -- Счётчик
            local count_txt  = count .. "x"
            local tw, th     = surface.get_text_size(font_big, count_txt)
            surface.draw_text(sx-floor(tw/2)+2, sy-fh/2+10+2, 0,0,0,  floor(alpha*0.8), font_big, count_txt)
            surface.draw_text(sx-floor(tw/2),   sy-fh/2+10,   pr,pg,pb, alpha,            font_big, count_txt)

            -- Название
            local nw, _ = surface.get_text_size(font_med, cname)
            surface.draw_text(sx-floor(nw/2)+1, sy+14+1, 0,0,0,  floor(alpha*0.8), font_med, cname)
            surface.draw_text(sx-floor(nw/2),   sy+14,   pr,pg,pb, alpha,            font_med, cname)

            -- Рекорд
            if best > 1 then
                local bt    = "BEST: " .. best .. "x"
                local bw2,_ = surface.get_text_size(font_med, bt)
                surface.draw_text(sx-floor(bw2/2), sy+fh/2+6, 150,150,150, floor(alpha*0.7), font_med, bt)
            end

            -- Полоска таймера снизу
            local line_w = floor(fw * math.min(fade_timer/4.0, 1))
            renderer.rectangle(sx-line_w/2, sy+fh/2-3, line_w, 2, pr,pg,pb, alpha)
        end

        -- Kill попапы
        for i = #kill_popups, 1, -1 do
            local kp = kill_popups[i]
            kp.life  = kp.life - ft
            kp.y_off = kp.y_off - ft * 35

            if kp.life <= 0 then
                table.remove(kill_popups, i)
            else
                local ka    = floor(255 * math.min(kp.life, 1))
                local ktw,_ = surface.get_text_size(font_kill, kp.text)
                local kx    = pos_x - floor(ktw/2)
                local ky    = pos_y - fh_base/2 - 30 + floor(kp.y_off)
                local cr,cg,cb = get_combo_color(count)

                renderer.rectangle(kx-4, ky-2, ktw+8, 20, 0,0,0, floor(ka*0.6))
                surface.draw_text(kx+1, ky+1, 0,0,0,    floor(ka*0.8), font_kill, kp.text)
                surface.draw_text(kx,   ky,   cr,cg,cb,  ka,            font_kill, kp.text)
            end
        end
    end)
end
