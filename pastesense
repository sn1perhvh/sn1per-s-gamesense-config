local surface = require("gamesense/surface")
    local vel_font = surface.create_font("Arial", 28, 800, {0x010})

do
    local vel = {
        enabled = ui.new_checkbox("LUA", "B", "Velocity Meter"),
        x       = ui.new_slider("LUA", "B", "Vel X pos", 0, 100, 50),
        y       = ui.new_slider("LUA", "B", "Vel Y pos", 0, 100, 90),
    }

    local function refresh()
        local a = ui.get(vel.enabled)
        ui.set_visible(vel.x, a)
        ui.set_visible(vel.y, a)
    end
    ui.set_callback(vel.enabled, refresh)
    refresh()

    local floor  = math.floor
    local sin    = math.sin
    local cos    = math.cos
    local sqrt   = math.sqrt
    local min    = math.min
    local max    = math.max
    local format = string.format
    local pi     = math.pi

    local smooth_vel  = 0
    local peak_vel    = 0
    local peak_timer  = 0
    local flash_timer = 0
    local prev_vel    = 0

    client.set_event_callback("paint", function()
        if not ui.get(vel.enabled) then return end

        local me = entity.get_local_player()
        if not me or not entity.is_alive(me) then return end

        local vx, vy, vz = entity.get_prop(me, "m_vecVelocity")
        if not vx then return end

        local w, h  = client.screen_size()
        local ft    = globals.frametime()
        local t     = globals.realtime()

        local speed = sqrt(vx*vx + vy*vy)
        local xpos  = floor(w * ui.get(vel.x) / 100)
        local ypos  = floor(h * ui.get(vel.y) / 100)

        -- Плавное значение
        smooth_vel = smooth_vel + (speed - smooth_vel) * min(ft * 12, 1)

        -- Пиковая скорость
        if speed > peak_vel then
            peak_vel   = speed
            peak_timer = 2.0
            flash_timer = 0.15
        end
        peak_timer = peak_timer - ft
        if peak_timer <= 0 then
            peak_vel = max(peak_vel - ft * 80, smooth_vel)
        end
        flash_timer = max(flash_timer - ft, 0)

        -- Вспышка при ускорении
        local accel = speed - prev_vel
        prev_vel    = speed
        local boost = accel > 30

        -- Параметры спидометра
        local radius    = 70
        local thickness = 6
        local max_speed = 320
        local segments  = 120

        -- Цвет в зависимости от скорости
        local frac = min(smooth_vel / max_speed, 1)
        local sr, sg, sb
        if frac < 0.5 then
            local f = frac * 2
            sr = floor(0   + f * 255)
            sg = floor(255 - f * 55)
            sb = floor(255 - f * 255)
        else
            local f = (frac - 0.5) * 2
            sr = 255
            sg = floor(200 - f * 200)
            sb = 0
        end

        -- Фон круга
        renderer.circle(xpos, ypos, radius + 10, 0, 0, 0, 120)
        renderer.circle(xpos, ypos, radius + 8,  10, 10, 20, 180)

        -- Дуга фона (серая)
        local start_angle = 150
        local end_angle   = 390
        local arc_range   = end_angle - start_angle

        for s = 0, segments do
            local a0 = start_angle + (s     / segments) * arc_range
            local a1 = start_angle + ((s+1) / segments) * arc_range
            local r0 = math.rad(a0)
            local r1 = math.rad(a1)

            for th = 0, thickness do
                local ri = radius - th
                local x0s = xpos + floor(cos(r0) * ri)
                local y0s = ypos + floor(sin(r0) * ri)
                local x1s = xpos + floor(cos(r1) * ri)
                local y1s = ypos + floor(sin(r1) * ri)
                renderer.line(x0s, y0s, x1s, y1s, 30, 30, 40, 200)
            end
        end

        -- Дуга скорости (цветная)
        local speed_segs = floor(segments * frac)
        for s = 0, speed_segs do
            local sf   = s / segments
            local a0   = start_angle + sf * arc_range
            local a1   = start_angle + ((s+1)/segments) * arc_range
            local r0   = math.rad(a0)
            local r1   = math.rad(a1)

            -- Цвет градиент вдоль дуги
            local cf   = sf / max(frac, 0.01)
            local lr, lg, lb
            if cf < 0.5 then
                local f = cf * 2
                lr = floor(f * 255)
                lg = floor(255 - f * 55)
                lb = floor(255 - f * 255)
            else
                local f = (cf-0.5)*2
                lr = 255
                lg = floor(200 - f*200)
                lb = 0
            end

            -- Свечение (более толстое и прозрачное)
            for th = 0, thickness + 4 do
                local ri    = radius - th + 2
                local glow_a = floor(180 * (1 - th/(thickness+4)))
                if th <= thickness then glow_a = 230 end
                local x0s = xpos + floor(cos(r0) * ri)
                local y0s = ypos + floor(sin(r0) * ri)
                local x1s = xpos + floor(cos(r1) * ri)
                local y1s = ypos + floor(sin(r1) * ri)
                renderer.line(x0s, y0s, x1s, y1s, lr, lg, lb, glow_a)
            end
        end

        -- Пиковая отметка
        if peak_vel > 10 then
            local peak_frac = min(peak_vel / max_speed, 1)
            local pa = start_angle + peak_frac * arc_range
            local pr = math.rad(pa)
            for th = 0, thickness + 2 do
                local ri = radius - th + 2
                local px0 = xpos + floor(cos(pr) * ri)
                local py0 = ypos + floor(sin(pr) * ri)
                local px1 = xpos + floor(cos(pr) * (ri - 3))
                local py1 = ypos + floor(sin(pr) * (ri - 3))
                renderer.line(px0, py0, px1, py1, 255, 255, 255, 200)
            end
        end

        -- Центральное число (скорость)
        local spd_text = format("%d", floor(speed))
        local flash_a  = flash_timer > 0 and 255 or floor(200 + sin(t*3)*30)

        -- Тень текста
        local tw, th = surface.get_text_size(vel_font, spd_text)
        surface.draw_text(xpos - floor(tw/2) + 1, ypos - floor(th/2) - 14, 0,0,0, 200, vel_font, spd_text)
        surface.draw_text(xpos - floor(tw/2),     ypos - floor(th/2) - 15, sr,sg,sb, flash_a, vel_font, spd_text)

        -- Единица
        renderer.text(xpos+1, ypos+4+1, 0,0,0, 150, "c", 0, "u/s")
        renderer.text(xpos,   ypos+4,   200,200,200, 150, "c", 0, "u/s")

        -- Пиковое значение
        if peak_vel > 10 then
            local pk_text = format("MAX %d", floor(peak_vel))
            renderer.text(xpos, ypos+22, 255,255,255, 120, "c", 0, pk_text)
        end

        -- Буст подсветка
        if boost and accel > 50 then
            renderer.text(xpos, ypos-30, sr,sg,sb, floor(flash_a*0.8), "c", 0, "BOOST!")
        end

        -- BHop индикатор — показывает есть ли идеальный бхоп
        local on_ground = entity.get_prop(me, "m_fFlags")
        if on_ground and bit.band(on_ground, 1) == 0 and speed > 250 then
            renderer.circle(xpos, ypos + radius + 18, 4, sr, sg, sb, 200)
            renderer.text(xpos, ypos + radius + 25, sr,sg,sb, 180, "c", 0, "AIR")
        end
    end)
end
