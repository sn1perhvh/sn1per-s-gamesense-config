local function draw_3d_box(ctx, ent, x, y, z, r, g, b, a)
    local min_x, min_y, min_z = entity.get_prop(ent, "m_vecMins")
    local max_x, max_y, max_z = entity.get_prop(ent, "m_vecMaxs")
    
    if not min_x then return end

    local v = {
        {x + min_x, y + min_y, z + min_z}, {x + min_x, y + max_y, z + min_z},
        {x + max_x, y + max_y, z + min_z}, {x + max_x, y + min_y, z + min_z},
        {x + min_x, y + min_y, z + max_z}, {x + min_x, y + max_y, z + max_z},
        {x + max_x, y + max_y, z + max_z}, {x + max_x, y + min_y, z + max_z}
    }

    local connections = {
        {1,2}, {2,3}, {3,4}, {4,1},
        {5,6}, {6,7}, {7,8}, {8,5},
        {1,5}, {2,6}, {3,7}, {4,8}
    }

    for i=1, #connections do
        local p1 = v[connections[i][1]]
        local p2 = v[connections[i][2]]
        
        local x1, y1 = client.world_to_screen(ctx, p1[1], p1[2], p1[3])
        local x2, y2 = client.world_to_screen(ctx, p2[1], p2[2], p2[3])

        if x1 and x2 then
            client.draw_line(ctx, x1, y1, x2, y2, r, g, b, a)
        end
    end
end

