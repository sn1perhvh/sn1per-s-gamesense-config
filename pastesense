client.set_event_callback("weapon_fire", function(e)
    if client.userid_to_entindex(e.userid) == entity.get_local_player() then
        last_eye_pos = {client.eye_position()}
    end
end)

client.set_event_callback("bullet_impact", function(e)
    if not ui.get(tracer) then return end
    
    me = entity.get_local_player()
    if client.userid_to_entindex(e.userid) ~= me then return end
    
    cur_tick = globals.tickcount()
    duration = ui.get(duration_slider) * 0.1
    
    if cur_tick == last_tick and #queue > 0 then
        queue[#queue].x2 = e.x
        queue[#queue].y2 = e.y
        queue[#queue].z2 = e.z
    else
        table.insert(queue, {
            x1 = last_eye_pos[1], y1 = last_eye_pos[2], z1 = last_eye_pos[3],
            x2 = e.x, y2 = e.y, z2 = e.z,
            start_time = globals.curtime(),
            end_time = globals.curtime() + duration
        })
    end
    
    last_tick = cur_tick
end)

client.set_event_callback("paint", function()
    if not ui.get(tracer) then return end
    
    curtime = globals.curtime()
    r, g, b, a = ui.get(color_picker)
    thickness = ui.get(thickness_slider)
    s = 3 

    for i = #queue, 1, -1 do
        data = queue[i]
        
        if curtime > data.end_time then
            table.remove(queue, i)
        else
            alpha_factor = (data.end_time - curtime) / (data.end_time - data.start_time)
            cur_a = a * alpha_factor
            
            x1, y1 = renderer.world_to_screen(data.x1, data.y1, data.z1)
            x2, y2 = renderer.world_to_screen(data.x2, data.y2, data.z2)
            
            if x1 and x2 then
                for offset = 0, thickness - 1 do
                    renderer.line(x1 + offset, y1, x2 + offset, y2, r, g, b, cur_a)
                end

                for offset = 0, math.max(0, thickness - 2) do
                    renderer.line(x2 - s + offset, y2 - s, x2 + s + offset, y2 + s, r, g, b, cur_a)
                    renderer.line(x2 - s + offset, y2 + s, x2 + s + offset, y2 - s, r, g, b, cur_a)
                end
            end
        end
    end
end)

client.set_event_callback("round_prestart", function()
    queue = {}
end)
