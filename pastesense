local function get_rainbow(speed, offset)
    local t = (globals.curtime() * speed + offset) % 1
    local i = t * 6
    local f = i - math.floor(i)
    local q = 1 - f
    if i < 1 then return 255, f*255, 0 elseif i < 2 then return q*255, 255, 0 elseif i < 3 then return 0, 255, f*255
    elseif i < 4 then return 0, q*255, 255 elseif i < 5 then return f*255, 0, 255 else return 255, 0, q*255 end
end

local function lerp(a, b, t)
    return a + (b - a) * t
end

