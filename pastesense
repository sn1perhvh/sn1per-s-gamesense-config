    local max   = math.max
    local pi2   = math.pi * 2

    local grid = {}
    for i = 0, 64 do grid[i] = {} end

    local sw, sh = client.screen_size()

    local function fill_tri(x1,y1, x2,y2, x3,y3, r,g,b,a)
        -- Отсекаем треугольники которые слишком большие (близко к камере)
        local minx = math.min(x1,x2,x3)
        local maxx = math.max(x1,x2,x3)
        local miny = math.min(y1,y2,y3)
        local maxy = math.max(y1,y2,y3)
        -- Если треугольник больше четверти экрана — пропускаем
        if maxx - minx > sw * 0.25 then return end
        if maxy - miny > sh * 0.25 then return end
        -- Если треугольник вне экрана — пропускаем
        if maxx < 0 or minx > sw then return end
        if maxy < 0 or miny > sh then return end

        if y1 > y2 then x1,y1,x2,y2 = x2,y2,x1,y1 end
        if y1 > y3 then x1,y1,x3,y3 = x3,y3,x1,y1 end
        if y2 > y3 then x2,y2,x3,y3 = x3,y3,x2,y2 end
        y1 = floor(y1)
        y2 = floor(y2)
        y3 = floor(y3)
        local h = y3 - y1
        if h == 0 then return end
        for y = y1, y3 do
            if y >= 0 and y <= sh then
                local upper = y < y2
                local seg   = upper and (y2 - y1) or (y3 - y2)
                if seg == 0 then seg = 1 end
                local t1 = (y - y1) / h
                local t2 = upper and ((y - y1) / seg) or ((y - y2) / seg)
                local xa  = x1 + (x3 - x1) * t1
                local xb  = upper and (x1 + (x2 - x1) * t2) or (x2 + (x3 - x2) * t2)
                if xa > xb then xa, xb = xb, xa end
                -- Клиппинг по X
                xa = math.max(xa, 0)
                xb = math.min(xb, sw)
                if xa < xb then
                    line(floor(xa), y, floor(xb), y, r, g, b, a)
                end
            end
        end
    end

    local function get_col(mode, frac, spd, r1,g1,b1,a1, r2,g2,b2,a2)
        local cr,cg,cb,ca = r1,g1,b1,a1
        if mode == "Rainbow" then
            local t  = (globals.curtime() * spd + frac) % 1
            local ci = t * 6
            local f  = ci - floor(ci)
            local q  = 1 - f
            if     ci < 1 then cr,cg,cb = 255,f*255,0
            elseif ci < 2 then cr,cg,cb = q*255,255,0
            elseif ci < 3 then cr,cg,cb = 0,255,f*255
            elseif ci < 4 then cr,cg,cb = 0,q*255,255
            elseif ci < 5 then cr,cg,cb = f*255,0,255
            else            cr,cg,cb = 255,0,q*255 end
            ca = a1
        elseif mode == "Gradient" then
            -- Зеркалим: идёт color1->color2->color1 по кругу без обрыва
            local t = frac * 2
            if t > 1 then t = 2 - t end
            cr = floor(r1+(r2-r1)*t)
            cg = floor(g1+(g2-g1)*t)
            cb = floor(b1+(b2-b1)*t)
            ca = floor(a1+(a2-a1)*t)
        end
        return cr,cg,cb,ca
    end

    client.set_event_callback("paint", function()
        if not ui.get(nim_cfg.enabled) then return end
        if not ui.get(tp[1]) or not ui.get(tp[2]) then return end

        local me = entity.get_local_player()
        if not me or not entity.is_alive(me) then return end

        local hx, hy, hz = entity.hitbox_position(me, 0)
        if not hx then return end

        local R        = ui.get(nim_cfg.radius)
        local r        = ui.get(nim_cfg.tube)
        local height   = ui.get(nim_cfg.height)
        local mode     = ui.get(nim_cfg.mode)
        local spd      = ui.get(nim_cfg.speed) * 0.2
        local do_pulse = ui.get(nim_cfg.pulse)
        local pulse_sp = ui.get(nim_cfg.pulse_sp) * 0.3
        local r1,g1,b1,a1 = ui.get(nim_cfg.color1)
        local r2,g2,b2,a2 = ui.get(nim_cfg.color2)
        local is_simple   = ui.get(nim_cfg.simple)

        local base_z = hz + height

        local pal
        if do_pulse then
            pal = floor(255 * (0.3 + 0.7 * ((sin(globals.curtime() * pulse_sp) + 1) * 0.5)))
        else
            pal = 255
        end

        if is_simple then
            local sm = max(floor(R * 1.8), 32)
            for iu = 0, sm - 1 do
                local u0 = (iu     / sm) * pi2
                local u1 = ((iu+1) / sm) * pi2
                local sx1,sy1 = w2s(hx + cos(u0)*R, hy + sin(u0)*R, base_z)
                local sx2,sy2 = w2s(hx + cos(u1)*R, hy + sin(u1)*R, base_z)
                if sx1 and sx2 then
                    local cr,cg,cb,ca = get_col(mode, iu/sm, spd, r1,g1,b1,a1, r2,g2,b2,a2)
                    for ot = -2, 2 do
                        line(sx1, sy1+ot, sx2, sy2+ot, cr,cg,cb, pal)
                    end
                end
            end
            return
        end

        local sm = max(floor(R * 0.9), 16)
        local st = max(floor(r  * 1.8), 5)

        local cu_t, su_t = {}, {}
        for iu = 0, sm do
            local u = (iu/sm)*pi2
            cu_t[iu] = cos(u)
            su_t[iu] = sin(u)
        end
        local cv_t, sv_t = {}, {}
        for iv = 0, st do
            local v = (iv/st)*pi2
            cv_t[iv] = cos(v)
            sv_t[iv] = sin(v)
        end

        for iu = 0, sm do
            local cu  = cu_t[iu]
            local su  = su_t[iu]
            local row = grid[iu]
            for iv = 0, st do
                local rho    = R + r * cv_t[iv]
                local sx, sy = w2s(
                    hx + rho * cu,
                    hy + rho * su,
                    base_z + r * sv_t[iv]
                )
                row[iv] = sx and {sx, sy} or false
            end
        end

        for iu = 0, sm - 1 do
            local frac_u = iu / sm
            local row0   = grid[iu]
            local row1   = grid[iu + 1]
            local cr,cg,cb,ca = get_col(mode, frac_u, spd, r1,g1,b1,a1, r2,g2,b2,a2)
            ca = pal

            for iv = 0, st - 1 do
                local A = row0[iv]
                local B = row1[iv]
                local C = row0[iv + 1]
                local D = row1[iv + 1]

                if A and B and C and D then
                    local ax,ay = A[1],A[2]
                    local bx,by = B[1],B[2]
                    local cx,cy = C[1],C[2]
                    local dx,dy = D[1],D[2]

                    -- Заливка двух треугольников с той же альфой
                    fill_tri(ax,ay, bx,by, dx,dy, cr,cg,cb, ca)
                    fill_tri(ax,ay, cx,cy, dx,dy, cr,cg,cb, ca)
                end
            end
        end
    end)
end
