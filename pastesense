-- aspect ratio
 function set_aspect_ratio(aspect_ratio_multiplier)
	 screen_width, screen_height = client_screen_size()
	 aspectratio_value = (screen_width*aspect_ratio_multiplier)/screen_height

	if aspect_ratio_multiplier == 1 then
		aspectratio_value = 0
	end
	client_set_cvar("r_aspectratio", tonumber(aspectratio_value))
end

 function gcd(m, n)
	while m ~= 0 do
		m, n = math_fmod(n, m), m;
	end

	return n
end

 aspect_ratio_table = {}

 screen_width, screen_height = client_screen_size()
for i=1, 200 do
	 i2=i*0.01
	i2 = 2 - i2
	 divisor = gcd(screen_width*i2, screen_height)
	if screen_width*i2/divisor < 100 or i2 == 1 then
		aspect_ratio_table[i] = screen_width*i2/divisor .. ":" .. screen_height/divisor
	end
end

 aspect_ratio_reference = ui.new_slider("LUA", "B", "Force aspect ratio", 1, 199, 100, true, "%", 1, aspect_ratio_table)

 function on_aspect_ratio_changed()
	 aspect_ratio = ui_get(aspect_ratio_reference)*0.01
	aspect_ratio = 2 - aspect_ratio
	set_aspect_ratio(aspect_ratio)
end

ui.set_callback(aspect_ratio_reference, on_aspect_ratio_changed)
