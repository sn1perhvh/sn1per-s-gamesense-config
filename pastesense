    if player == 0 then return end
    
    local x, y, z = entity_get_prop(player, "m_vecOrigin")
    if x == nil then return end
    
    local voZ = entity_get_prop(player, "m_vecViewOffset[2]") or 64
    
    damage_indicator_displays[player] = {damage, globals_realtime(), x, y, z + voZ + 25}
